# deploy/fly.io/fly.env — runtime config for Fly.io Machine
#
# Activation: fly deploy (pushes OCI image to Fly registry, restarts Machine)
# Storage: Fly volume mounted at /data
# Exposure: Fly proxy (TLS terminated by Fly)
#
# SECRET_KEY_BASE must be set as a Fly secret — do not store in this file.
#   fly secrets set SECRET_KEY_BASE=$(mix phx.gen.secret)
#   Generate with: mix phx.gen.secret  (or: openssl rand -base64 48)
# DATABASE_PATH and EVENT_LOG_PATH must point into the mounted Fly volume.

BIND_ADDRESS=0.0.0.0
BIND_PORT=8080
URL_BASE=https://seatzero.fly.dev
DATABASE_PATH=/data/seatzero.db
EVENT_LOG_PATH=/data/holdem.db
FORCE_SSL=true
