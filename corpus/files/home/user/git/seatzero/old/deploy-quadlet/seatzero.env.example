# /etc/seatzero/seatzero.env
#
# Copy to /etc/seatzero/seatzero.env and fill in SECRET_KEY_BASE.
#
#   sudo install -m 600 -o root -g root seatzero.env.example /etc/seatzero/seatzero.env
#   sudo $EDITOR /etc/seatzero/seatzero.env
#
# SECRET_KEY_BASE -- required, no default.
#   Generate with: mix phx.gen.secret
#   Or without Mix: openssl rand -base64 48
#   Never reuse between environments. Never commit to version control.
#
LIMA_MIKE_BASE=

DATABASE_PATH=/data/seatzero.db
EVENT_LOG_PATH=/data/holdem.db
URL_BASE=http://localhost:4000
BIND_ADDRESS=0.0.0.0
BIND_PORT=4000
