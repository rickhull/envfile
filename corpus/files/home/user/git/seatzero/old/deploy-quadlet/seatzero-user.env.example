# ~/.config/seatzero/seatzero.env
#
# Copy to ~/.config/seatzero/seatzero.env and fill in SECRET_KEY_BASE.
#
#   mkdir -p ~/.config/seatzero
#   cp deploy/quadlet/seatzero-user.env.example ~/.config/seatzero/seatzero.env
#   $EDITOR ~/.config/seatzero/seatzero.env
#
# SECRET_KEY_BASE -- required, no default.
#   Generate with: mix phx.gen.secret
#   Or without Mix: openssl rand -base64 48
#   Never reuse between environments. Never commit to version control.
#
FOXTROT_SIERRA_BASE=

DATABASE_PATH=/home/USER/.local/share/seatzero/seatzero.db
EVENT_LOG_PATH=/home/USER/.local/share/seatzero/holdem.db
URL_BASE=http://localhost:4000
BIND_ADDRESS=0.0.0.0
BIND_PORT=4000
