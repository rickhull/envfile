# deploy/oci/ht.env — OCI image config for homelab host (ht.lan)
#
# Activation: podman via Justfile oci-run target
# Storage: /data bind-mounted from host
# Exposure: direct LAN HTTP, or Caddy on gw for external (see docs/planning/DEPLOYMENT_EXTERNAL.md)
#
# SECRET_KEY_BASE must be supplied externally — do not store in this file.
#   Export it in your shell before running, or pass via: just oci::run env_file=...
#   Generate with: mix phx.gen.secret  (or: openssl rand -base64 48)

BIND_ADDRESS=0.0.0.0
BIND_PORT=4002
URL_BASE=http://ht.lan:4002
DATABASE_PATH=/data/seatzero.db
EVENT_LOG_PATH=/data/holdem.db
