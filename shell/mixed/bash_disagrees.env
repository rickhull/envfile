# bash_disagrees.env — valid envfile; bash source produces different values
#
# envfile: double-quoted values are purely literal, no expansion
# bash:    expands $VAR and `cmd` inside double quotes
#
# These are out of scope for envfile's bash-sourcing guiding light.
# If you source this file with bash, you get different values.

DOUBLE_DOLLAR="$HOME"
DOUBLE_BACKTICK="`whoami`"
