# accepted.env — valid assignments; all should pass with 0 errors

# bare values
BIND_PORT=4321
DATABASE_PATH=/data/seatzero.db
EVENT_LOG_PATH=/data/holdem.db
SECRET_KEY_BASE=x703r57fJoLj2oS1yEXkiVmkxWrtZu9u
EMPTY_VALUE=
VALUE_WITH_EQUALS=base64://abc=def==
COLOR=#ff0

# key forms
_UNDERSCORE_KEY=ok
KEY123=numbers_ok

# hash in values — # is only special as the first char of a line
HASH_ONLY=#
HASH_IN_VALUE=val#ue
HASH_AT_START_OF_VALUE=#comment_looking
HASH_IN_DOUBLE_QUOTED="value #not a comment"
HASH_IN_SINGLE_QUOTED='value #not a comment'
HASH_AT_START_OF_QUOTED="# looks like comment"
HASH_NO_SPACE=value#nospace

# quoted values
QUOTED_DOUBLE="hello world"
QUOTED_SINGLE='hello world'
QUOTED_WITH_EQUALS="a=b=c"
QUOTED_EMPTY_DOUBLE=""
QUOTED_EMPTY_SINGLE=''
QUOTED_DOUBLE_WITH_SINGLE="it's fine"
QUOTED_SINGLE_WITH_DOUBLE='she said "hi"'
QUOTED_BACKSLASH='path\to\file'

