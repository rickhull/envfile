# rejected.env — invalid assignments; each line (except this header) triggers an error

BIND_PORT=4000
123_BAD=oops
noequals
export FOO=bar
KEY = val
has space=value with spaces
-hasdash=value
=empty_key
	good_key_but_tab=value
UNTERMINATED_DOUBLE="no end quote
UNTERMINATED_SINGLE='no end quote
NESTED_SINGLE='can't nest'
MIXED_QUOTES="mixed'quotes"ok
WHITESPACE_AFTER_EQ= value
UNQUOTED_SPACE=hello world
UNQUOTED_SINGLE=it's
UNQUOTED_DOUBLE=say"hi"
UNQUOTED_BACKSLASH=path\to\file

# only # introduces a comment; other comment syntaxes are not special
INLINE_HASH_SPACE=value #not a comment
 #LEADING_SPACE_THEN_HASH=value
SQL_COMMENT=value -- not a comment
CPP_COMMENT=value // not a comment
BAT_COMMENT=value ;; not a comment
