#!/bin/sh
# envfile â€” general entry point (POSIX sh)

set -eu

script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd)

format=shell
language=
action=validate
config=
envfile=

# behavior knobs â€” empty means "use impl default"
envfile_bom=
envfile_crlf=
envfile_nul=
envfile_backslash_continuation=

fatal_error() {
  code=$1
  shift
  printf '%s: %s: %s\n' "$0" "$code" "$*" >&2
  exit 1
}

is_word() {
  case $1 in
    [A-Za-z_]*)
      rest=${1#?}
      case $rest in
        *[!A-Za-z0-9_]*) return 1 ;;
      esac
      return 0
      ;;
  esac
  return 1
}

is_language() {
  case $1 in
    [A-Za-z0-9]*)
      case $1 in
        *[!A-Za-z0-9_.-]*) return 1 ;;
      esac
      return 0
      ;;
  esac
  return 1
}

validate_bom()                    { case $1 in reject|warn|strip) ;; *) fatal_error FATAL_ERROR_BAD_ENVFILE_VALUE "ENVFILE_BOM=$1";; esac; }
validate_crlf()                   { case $1 in strip|ignore)     ;; *) fatal_error FATAL_ERROR_BAD_ENVFILE_VALUE "ENVFILE_CRLF=$1";; esac; }
validate_nul()                    { case $1 in reject|ignore)     ;; *) fatal_error FATAL_ERROR_BAD_ENVFILE_VALUE "ENVFILE_NUL=$1";; esac; }
validate_backslash_continuation() { case $1 in accept|ignore)    ;; *) fatal_error FATAL_ERROR_BAD_ENVFILE_VALUE "ENVFILE_BACKSLASH_CONTINUATION=$1";; esac; }

choose_impl() {
  fmt=$1
  lang=$2

  if [ -n "$lang" ]; then
    impl=$("$script_dir/lang" "$lang" envfile 2>/dev/null) || return 1
    printf '%s\n' "$impl"
    return 0
  fi

  case $fmt in
    native) set -- awk c go zig bash sh perl ;;
    shell|compat) set -- awk perl bash python sh ;;
  esac

  for lang in "$@"; do
    impl=$("$script_dir/lang" "$lang" envfile 2>/dev/null) || continue
    printf '%s\n' "$impl"
    return 0
  done

  return 1
}

# Parse ARGV â€” routing and envfile channels only
while [ $# -gt 0 ]; do
  case $1 in
    format=*)
      format=${1#format=}
      is_word "$format" || fatal_error FATAL_ERROR_BAD_ARG "format=$format"
      ;;
    language=*)
      language=${1#language=}
      is_language "$language" || fatal_error FATAL_ERROR_BAD_ARG "language=$language"
      ;;
    action=*)
      action=${1#action=}
      case $action in
        normalize|validate|dump|delta|apply) ;;
        *) fatal_error FATAL_ERROR_BAD_ARG "action=$action" ;;
      esac
      ;;
    config=*)
      config=${1#config=}
      [ -f "$config" ] || fatal_error FATAL_ERROR_NOT_FOUND "file=$config"
      ;;
    env=*)
      envfile=${1#env=}
      [ -f "$envfile" ] || fatal_error FATAL_ERROR_NOT_FOUND "file=$envfile"
      ;;
    [A-Za-z_][A-Za-z0-9_]*=*)
      fatal_error FATAL_ERROR_BAD_ARG "setting=$1"
      ;;
    *)
      break
      ;;
  esac
  shift
done

case $format in
  shell|native|compat) ;;
  *)
    fatal_error FATAL_ERROR_UNSUPPORTED "format=$format"
    ;;
esac

# Load behavior knobs from config file (mined silently; known values validated)
if [ -n "$config" ]; then
  while IFS= read -r line; do
    case $line in
      BOM=*)                    v=${line#BOM=};                    validate_bom "$v";                    envfile_bom=$v ;;
      CRLF=*)                   v=${line#CRLF=};                   validate_crlf "$v";                   envfile_crlf=$v ;;
      NUL=*)                    v=${line#NUL=};                    validate_nul "$v";                    envfile_nul=$v ;;
      BACKSLASH_CONTINUATION=*) v=${line#BACKSLASH_CONTINUATION=}; validate_backslash_continuation "$v"; envfile_backslash_continuation=$v ;;
    esac
  done < <(ENVFILE_FORMAT=native ENVFILE_ACTION=dump "$script_dir/envfile.awk" "$config" 2>/dev/null)
fi

# POSIX env vars override config file (already in environment; only fill gaps)
[ -z "$envfile_bom" ]                    && [ -n "${ENVFILE_BOM:-}" ]                    && { validate_bom "$ENVFILE_BOM";                                       envfile_bom=$ENVFILE_BOM; }
[ -z "$envfile_crlf" ]                   && [ -n "${ENVFILE_CRLF:-}" ]                   && { validate_crlf "$ENVFILE_CRLF";                                     envfile_crlf=$ENVFILE_CRLF; }
[ -z "$envfile_nul" ]                    && [ -n "${ENVFILE_NUL:-}" ]                    && { validate_nul "$ENVFILE_NUL";                                       envfile_nul=$ENVFILE_NUL; }
[ -z "$envfile_backslash_continuation" ] && [ -n "${ENVFILE_BACKSLASH_CONTINUATION:-}" ] && { validate_backslash_continuation "$ENVFILE_BACKSLASH_CONTINUATION"; envfile_backslash_continuation=$ENVFILE_BACKSLASH_CONTINUATION; }

# Format-gating: some passes are not applicable to all formats
if [ "$format" = "native" ]; then
  [ -n "$envfile_bom" ] && fatal_error FATAL_ERROR_UNSUPPORTED "format=native ENVFILE_BOM=$envfile_bom"
  [ "$envfile_backslash_continuation" = "accept" ] && fatal_error FATAL_ERROR_UNSUPPORTED "format=native ENVFILE_BACKSLASH_CONTINUATION=accept"
fi

impl=$(choose_impl "$format" "$language") || {
  if [ -n "$language" ]; then
    fatal_error FATAL_ERROR_UNSUPPORTED "language=$language"
  else
    fatal_error FATAL_ERROR_UNSUPPORTED "implementation=none"
  fi
}

# Build env prefix for impl invocation
envp="env ENVFILE_FORMAT=$format ENVFILE_ACTION=$action"
[ -n "$envfile" ]              && envp="$envp ENVFILE_ENV=$envfile"
[ -n "$envfile_bom" ]                    && envp="$envp ENVFILE_BOM=$envfile_bom"
[ -n "$envfile_crlf" ]                   && envp="$envp ENVFILE_CRLF=$envfile_crlf"
[ -n "$envfile_nul" ]                    && envp="$envp ENVFILE_NUL=$envfile_nul"
[ -n "$envfile_backslash_continuation" ] && envp="$envp ENVFILE_BACKSLASH_CONTINUATION=$envfile_backslash_continuation"

case $impl in
  */envfile.awk)
    exec $envp LC_ALL=C "$impl" "$@"
    ;;
  *)
    exec $envp "$impl" "$@"
    ;;
esac
