# delta/basic.env — native delta fixture; run against standard.env

# literal values
FOO=bar
PORT=8080

# references standard.env values
MYBIN=$HOME/bin
MYPATH=$HOME/bin:$PATH

# self-referential: uses value set earlier in this file
FULL=$MYBIN/tool

# unset reference — should produce LINE_ERROR_UNBOUND_REF
MISSING=$UNDEFINED
