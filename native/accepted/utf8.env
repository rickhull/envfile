# accepted.env — terminal-friendly native assignments; blank and # lines are ignored

# comments are ignored
FOO=bar
PORT=8080
EMPTY=
PATH=/usr/bin:/bin
foo=bar
9NUM=nine
BAD KEY=Grüße
LEAD=élan
TRAIL =café
DOLLAR=$HOME/bin
EQUALS=base64://abc=def==
SINGLE='hello world'
DOUBLE="hello world"
MIXED="it's fine"
HASH="#not a comment"
BACKSLASH="path\to\file"
UNICODE=Grüße
