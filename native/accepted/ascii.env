# accepted/ascii.env — terminal-friendly ASCII native assignments

# comments and blank lines are ignored
FOO=bar
PORT=8080
EMPTY=
PATH=/usr/bin:/bin
foo=bar
1DIGIT=one
BAD KEY=value
LEAD=value
TRAIL =value
BAD-DASH=value
DOLLAR=$HOME/bin
EQUALS=base64://abc=def==
SINGLE='hello world'
DOUBLE="hello world"
MIXED="it's fine"
HASH="#not a comment"
BACKSLASH="path\to\file"
